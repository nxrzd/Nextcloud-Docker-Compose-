# Copy to .env and fill in. NEVER commit your real .env (see .gitignore).
# Generate secrets with: openssl rand -base64 24

# --- Database ---
MARIADB_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=changeme_db

# --- Redis ---
REDIS_PASSWORD=changeme_redis

# --- Nextcloud admin (created on first run) ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme_admin

# Space-separated. Include your LAN IP and the public FQDN your proxy serves.
NEXTCLOUD_TRUSTED_DOMAINS=192.168.1.10 nextcloud.example.com

# IP/CIDR of your reverse proxy as the container sees it.
TRUSTED_PROXIES=192.168.1.0/24

# Public URL users reach through the reverse proxy.
OVERWRITEHOST=nextcloud.example.com
OVERWRITECLIURL=https://nextcloud.example.com

# Where the app port is published. localhost-only by default (proxy on same host).
# Use <lan-ip>:8080 if your proxy runs on a different machine.
HTTP_BIND=127.0.0.1:8080

# Host path for user data. ./data for testing; a dedicated/encrypted mount in prod,
# e.g. /mnt/storage/nextcloud/data
NEXTCLOUD_DATA_PATH=./data
